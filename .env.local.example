# KIS market-data environment: paper | prod
KIS_DATA_ENV=paper

# Keep paper and production data credentials separate. The active profile is
# selected by KIS_DATA_ENV. Production credentials remain read-only in this app.
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PROD_DATA_APP_KEY=
KIS_PROD_DATA_APP_SECRET=

# Legacy single-profile names are still accepted as a temporary fallback.
KIS_APP_KEY=
KIS_APP_SECRET=

# Optional for the Phase 0 market-data probe.
KIS_HTS_ID=
KIS_DOMESTIC_SYMBOL=005930
KIS_US_EXCHANGE=NAS
KIS_US_SYMBOL=AAPL

# Free default: use KIS realtime US ETFs as direction proxies.
# QQQ is not NQ/MNQ and USO is not CL/MCL. The UI must show PROXY_LIVE.
CME_DATA_MODE=proxy
KIS_NASDAQ_PROXY_EXCHANGE=NAS
KIS_NASDAQ_PROXY_SYMBOL=QQQ
KIS_RUSSELL_PROXY_EXCHANGE=AMS
KIS_RUSSELL_PROXY_SYMBOL=IWM
KIS_OIL_PROXY_EXCHANGE=AMS
KIS_OIL_PROXY_SYMBOL=USO

# Domestic derivatives remain read-only and require their actual contract code.
KIS_KR_DAY_FUTURES_SYMBOL=
KIS_KR_NIGHT_FUTURES_SYMBOL=

# Disclosure providers. OpenDART requires the 40-character key. SEC has no
# API key, but requires an identifiable application name/version and email.
DART_CRTFC_KEY=
# Format example (intentionally rejected placeholder): PaperTradingHTS/0.0.1 contact@example.com
SEC_USER_AGENT=

# Local health runs without network by default.
KIS_HEALTH_LIVE=false
KIS_PROBE_SECONDS=15

# Required for any live network health/probe command.
KIS_LIVE_ACK=

# Local simulation only. Advanced queue remains an estimate, never a real order.
PAPER_FILL_PROFILE=INITIAL_CONSERVATIVE_V1
PAPER_QUEUE_SAFETY_FACTOR=1.25
